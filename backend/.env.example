# Opcion A: URL completa (Neon, Railway, Supabase, etc.)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Opcion B: variables individuales (local)
# DB_USER=postgres
# DB_HOST=127.0.0.1
# DB_NAME=gmao
# DB_PASSWORD=change_me
# DB_PORT=5432
# DB_SSL=false

PORT=3000

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=alerts@example.com
